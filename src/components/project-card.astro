---
import Link from '@/components/link.astro'
import { Badge } from '@/components/ui/badge'
import { formatDate } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

interface Props {
  project: CollectionEntry<'projects'>
}

const { project } = Astro.props
const githubRepo = project.data.githubRepo ?? null
---

<div
  class="hover:bg-muted/50 relative rounded-xl border p-4 transition-colors duration-300 ease-in-out"
>
  <Link
    href={`/projects/${project.id}`}
    class="flex flex-col gap-4 sm:flex-row"
  >
    {
      project.data.image && (
        <div class="w-full sm:max-w-3xs sm:shrink-0">
          <Image
            src={project.data.image}
            alt={project.data.name}
            width={1200}
            height={630}
            class="object-cover"
          />
        </div>
      )
    }
    <div class="grow">
      <h3 class="mb-1 text-lg font-medium">
        {project.data.name}
      </h3>
      <p class="text-muted-foreground mb-2 text-sm">
        {project.data.description}
      </p>
      {
        project.data.startDate && (
          <p class="text-muted-foreground/70 mb-2 flex items-center gap-x-1.5 text-xs">
            <span class="flex items-center gap-x-1.5">
              <Icon name="lucide:calendar" class="size-3" />
              <span>
                {formatDate(project.data.startDate)}
                {project.data.endDate
                  ? ` → ${formatDate(project.data.endDate)}`
                  : ' → Present'}
              </span>
            </span>
          </p>
        )
      }
      {
        project.data.tags && (
          <div class="flex flex-wrap gap-2">
            {project.data.tags.map((tag) => (
              <Badge variant="muted">{tag}</Badge>
            ))}
          </div>
        )
      }
    </div>
  </Link>
  {
    githubRepo && (
      <span
        class="text-muted-foreground/70 absolute top-4 right-4 flex items-center gap-x-1 text-xs"
        data-github-repo={githubRepo}
        hidden
      >
        <Icon name="lucide:star" class="size-3" />
        <span class="github-stars-count" />
      </span>
    )
  }
</div>

<script>
  const formatStars = (n: number): string => {
    if (n >= 1_000_000) return (n / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M'
    if (n >= 1_000) return (n / 1_000).toFixed(1).replace(/\.0$/, '') + 'k'
    return String(n)
  }

  const cache = new Map<string, Promise<number | null>>()

  const fetchStars = (repo: string): Promise<number | null> => {
    if (!cache.has(repo)) {
      cache.set(
        repo,
        fetch(`https://api.github.com/repos/${repo}`)
          .then((r) => (r.ok ? r.json() : null))
          .then((d) => (d ? (d.stargazers_count as number) : null))
          .catch(() => null),
      )
    }
    return cache.get(repo)!
  }

  const hydrate = async () => {
    document
      .querySelectorAll<HTMLElement>('[data-github-repo]')
      .forEach(async (el) => {
        const repo = el.dataset.githubRepo
        if (!repo) return
        const stars = await fetchStars(repo)
        if (stars == null) return
        const countEl = el.querySelector<HTMLElement>('.github-stars-count')
        if (countEl) countEl.textContent = formatStars(stars)
        el.setAttribute('title', `${stars.toLocaleString()} stars on GitHub`)
        el.hidden = false
      })
  }

  document.addEventListener('astro:page-load', hydrate)
</script>
