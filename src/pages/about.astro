---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import PageHead from '@/components/page-head.astro'
import SocialIcons from '@/components/social-icons.astro'
import Layout from '@/layouts/layout.astro'
import { getEntry } from 'astro:content'

const author = await getEntry('authors', 'ryder')
const { name, pronouns, avatar, bio, github, mail, website } = author.data

const links = [
  github && { href: github, label: 'GitHub' },
  mail && { href: `mailto:${mail}`, label: 'Email' },
  website && website !== github && { href: website, label: 'Website' },
].filter(Boolean) as { href: string; label: string }[]
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="About" />
  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:info' }]} />

  <section class="flex flex-col items-center gap-6 py-8 text-center sm:flex-row sm:items-start sm:text-left">
    <img
      src={avatar}
      alt={name}
      class="size-28 rounded-full object-cover ring-2 ring-border"
    />
    <div class="flex flex-col gap-3">
      <div>
        <h1 class="text-3xl font-semibold">{name}</h1>
        {pronouns && <p class="text-sm text-muted-foreground">{pronouns}</p>}
      </div>
      {bio && <p class="text-base text-foreground/80">{bio}</p>}
      {links.length > 0 && <SocialIcons links={links} />}
    </div>
  </section>
</Layout>
