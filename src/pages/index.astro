---
import BlogCard from '@/components/blog-card.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import ProjectCard from '@/components/project-card.astro'
import { buttonVariants } from '@/components/ui/button'
import { SITE } from '@/consts'
import Layout from '@/layouts/layout.astro'
import { getRecentPosts, getRecentProjects } from '@/lib/data-utils'

const blog = await getRecentPosts(SITE.featuredPostCount)
const projects = await getRecentProjects(SITE.featuredProjectCount)
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Home" />
  <!-- <section class="rounded-lg border"> -->
  <!--   <div class="flex flex-col space-y-1.5 p-6"> -->
  <!--     <h3 class="text-4xl leading-none font-medium">Ryder Casazza</h3> -->
  <!--     <p class="text-muted-foreground text-sm">Math Software Something.</p> -->
  <!--   </div> -->
  <!--   <div class="p-6 pt-0"> -->
  <!--     <p class="text-muted-foreground text-sm"> -->
  <!--       I write Rust, daily drive NixOS, and spend maybe too long thinking about -->
  <!--       whether something is actually right. That's kind of the point though. -->
  <!--     </p> -->
  <!--   </div> -->
  <!-- </section> -->
  <section class="flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">Latest posts</h2>
    <ul class="flex flex-col gap-y-4">
      {
        blog.map((post) => (
          <li>
            <BlogCard entry={post} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href="/blog"
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        See all posts <span
          class="ml-1.5 transition-transform group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>
  </section>
  {
    projects.length > 0 && (
      <section class="flex flex-col gap-y-4">
        <h2 class="text-2xl font-medium">Latest projects</h2>
        <ul class="flex flex-col gap-y-4">
          {projects.map((project) => (
            <li>
              <ProjectCard project={project} />
            </li>
          ))}
        </ul>
        <div class="flex justify-center">
          <Link
            href="/projects"
            class={buttonVariants({ variant: 'ghost' }) + ' group'}
          >
            See all projects{' '}
            <span class="ml-1.5 transition-transform group-hover:translate-x-1">
              &rarr;
            </span>
          </Link>
        </div>
      </section>
    )
  }
</Layout>
